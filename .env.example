# 로컬
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 프로덕션(Vercel): 예) https://tag.eternalbeam.com
# NEXT_PUBLIC_APP_URL=https://tag.eternalbeam.com

# Project URL: 대시보드 Connect 메뉴의 Project URL (예: https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# API Keys: Settings → API. 이미지 업로드/버킷 생성에는 반드시 아래 service_role 키를 넣는 것을 권장합니다.
# (Publishable/anon 키만 넣으면 Storage에서 403·500이 날 수 있습니다.)
SUPABASE_SERVICE_ROLE_KEY=

# (선택) DB 마이그레이션 스크립트용. Settings → Database → Connection string → URI
# 예: npm run db:apply-owner-key
DATABASE_URL=

# 클라이언트용(선택). 없으면 service role만으로도 서버 API는 동작합니다.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

SUPABASE_PET_BUCKET=pet-assets

# (선택) 견주 ?owner= 링크 분실 시 owner_key 초기화용. POST /api/pet/owner-reset 의 secret과 동일한 긴 임의 문자열.
# TAG_OWNER_RESET_SECRET=

REPLICATE_API_TOKEN=
REPLICATE_IMG2IMG_MODEL=stability-ai/stable-diffusion-img2img

NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...
TOSS_PAYMENT_AMOUNT=1000
